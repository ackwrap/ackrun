#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

generate_token() {
	local token
	token="$(head -c 32 /dev/urandom | sha256sum | cut -c 1-48)"
	[ "${#token}" -eq 48 ] || return 1
	uci -q set ackwrap.main.api_token="$token"
	uci -q commit ackwrap
	echo "$token"
}

start_service() {
	local enabled port api_token data_dir logger
	config_load ackwrap
	config_get_bool enabled main enabled 1
	[ "$enabled" -eq 1 ] || return 0
	config_get port main port 8080
	case "$port" in
		''|*[!0-9]*)
			logger -t ackwrap "invalid listen port: expected 1-65535"
			return 1
			;;
	esac
	if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
		logger -t ackwrap "invalid listen port: expected 1-65535"
		return 1
	fi
	config_get api_token main api_token
	config_get data_dir main data_dir /etc/ackwrap
	config_get_bool logger main logger 1
	[ -n "$api_token" ] || api_token="$(generate_token)"
	case "$api_token" in
		*[!A-Za-z0-9._~-]*)
			logger -t ackwrap "invalid API token: use only A-Z, a-z, 0-9, dot, underscore, tilde, or hyphen"
			return 1
			;;
	esac
	if [ "${#api_token}" -lt 16 ]; then
		logger -t ackwrap "invalid API token: expected at least 16 characters"
		return 1
	fi

	procd_open_instance
	procd_set_param command /usr/bin/ackwrap
	procd_set_param env ACKWRAP_LISTEN_ADDR="0.0.0.0:$port"
	procd_append_param env ACKWRAP_API_TOKEN="$api_token"
	procd_append_param env ACKWRAP_DATA_DIR="$data_dir"
	procd_append_param env ACKWRAP_BINARY_DIR="$data_dir/bin"
	procd_set_param respawn 3600 5 5
	procd_set_param limits nofile="1048576 1048576"
	if [ "$logger" -eq 1 ]; then
		procd_set_param stdout 1
		procd_set_param stderr 1
	fi
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger ackwrap
}

reload_service() {
	stop
	start
}
